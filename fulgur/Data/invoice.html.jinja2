<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Invoice {{ invoice.number }}</title>
  <link rel="stylesheet" href="invoice.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <div class="page">

    <!-- ── HEADER ─────────────────────────────────────────────── -->
    <header class="inv-header">
      <div class="inv-brand">
        {% if seller.logo_url %}
          <img class="inv-logo" src="{{ seller.logo_url }}" alt="{{ seller.name }} logo" />
        {% else %}
          <span class="inv-logo-placeholder">{{ seller.name | truncate(2, True, '') | upper }}</span>
        {% endif %}
        <span class="inv-company-name">{{ seller.name }}</span>
      </div>

      <div class="inv-meta">
        <div class="inv-meta-row">
          <span class="inv-meta-label">Invoice</span>
          <span class="inv-meta-value inv-number">#{{ invoice.number }}</span>
        </div>
        <div class="inv-meta-row">
          <span class="inv-meta-label">Date Issued</span>
          <span class="inv-meta-value">{{ invoice.issue_date }}</span>
        </div>
        <div class="inv-meta-row">
          <span class="inv-meta-label">Due Date</span>
          <span class="inv-meta-value {% if invoice.is_overdue %}overdue{% endif %}">
            {{ invoice.due_date }}
            {% if invoice.is_overdue %}<span class="badge badge--overdue">Overdue</span>{% endif %}
          </span>
        </div>
        <div class="inv-meta-row">
          <span class="inv-meta-label">Status</span>
          <span class="inv-meta-value">
            <span class="badge badge--{{ invoice.status | lower }}">{{ invoice.status | capitalize }}</span>
          </span>
        </div>
      </div>
    </header>

    <div class="inv-divider"></div>

    <!-- ── PARTIES ────────────────────────────────────────────── -->
    <section class="inv-parties">

      <div class="inv-party inv-party--from">
        <p class="inv-party-label">From</p>
        <p class="inv-party-name">{{ seller.name }}</p>
        {% if seller.tax_id %}
          <p class="inv-party-detail">Tax ID: {{ seller.tax_id }}</p>
        {% endif %}
        <p class="inv-party-detail">{{ seller.address_line1 }}</p>
        {% if seller.address_line2 %}
          <p class="inv-party-detail">{{ seller.address_line2 }}</p>
        {% endif %}
        <p class="inv-party-detail">{{ seller.city }}, {{ seller.state }} {{ seller.postal_code }}</p>
        <p class="inv-party-detail">{{ seller.country }}</p>
        {% if seller.email %}
          <p class="inv-party-detail"><a href="mailto:{{ seller.email }}">{{ seller.email }}</a></p>
        {% endif %}
        {% if seller.phone %}
          <p class="inv-party-detail">{{ seller.phone }}</p>
        {% endif %}
        {% if seller.website %}
          <p class="inv-party-detail"><a href="{{ seller.website }}">{{ seller.website }}</a></p>
        {% endif %}
      </div>

      <div class="inv-party inv-party--to">
        <p class="inv-party-label">Bill To</p>
        <p class="inv-party-name">{{ buyer.name }}</p>
        {% if buyer.contact_name %}
          <p class="inv-party-detail">Attn: {{ buyer.contact_name }}</p>
        {% endif %}
        {% if buyer.tax_id %}
          <p class="inv-party-detail">Tax ID: {{ buyer.tax_id }}</p>
        {% endif %}
        <p class="inv-party-detail">{{ buyer.address_line1 }}</p>
        {% if buyer.address_line2 %}
          <p class="inv-party-detail">{{ buyer.address_line2 }}</p>
        {% endif %}
        <p class="inv-party-detail">{{ buyer.city }}, {{ buyer.state }} {{ buyer.postal_code }}</p>
        <p class="inv-party-detail">{{ buyer.country }}</p>
        {% if buyer.email %}
          <p class="inv-party-detail"><a href="mailto:{{ buyer.email }}">{{ buyer.email }}</a></p>
        {% endif %}
      </div>

      {% if invoice.ship_to %}
      <div class="inv-party inv-party--ship">
        <p class="inv-party-label">Ship To</p>
        <p class="inv-party-name">{{ invoice.ship_to.name }}</p>
        <p class="inv-party-detail">{{ invoice.ship_to.address_line1 }}</p>
        {% if invoice.ship_to.address_line2 %}
          <p class="inv-party-detail">{{ invoice.ship_to.address_line2 }}</p>
        {% endif %}
        <p class="inv-party-detail">{{ invoice.ship_to.city }}, {{ invoice.ship_to.state }} {{ invoice.ship_to.postal_code }}</p>
        <p class="inv-party-detail">{{ invoice.ship_to.country }}</p>
      </div>
      {% endif %}

    </section>

    <!-- ── REFERENCE / PO ─────────────────────────────────────── -->
    {% if invoice.po_number or invoice.reference or invoice.project %}
    <section class="inv-references">
      {% if invoice.po_number %}
        <div class="inv-ref-item">
          <span class="inv-ref-label">PO Number</span>
          <span class="inv-ref-value">{{ invoice.po_number }}</span>
        </div>
      {% endif %}
      {% if invoice.reference %}
        <div class="inv-ref-item">
          <span class="inv-ref-label">Reference</span>
          <span class="inv-ref-value">{{ invoice.reference }}</span>
        </div>
      {% endif %}
      {% if invoice.project %}
        <div class="inv-ref-item">
          <span class="inv-ref-label">Project</span>
          <span class="inv-ref-value">{{ invoice.project }}</span>
        </div>
      {% endif %}
    </section>
    {% endif %}

    <!-- ── LINE ITEMS TABLE ───────────────────────────────────── -->
    <section class="inv-items-section">
      <table class="inv-table">
        <thead>
          <tr>
            <th class="col-num">#</th>
            <th class="col-desc">Description</th>
            <th class="col-qty">Qty</th>
            <th class="col-unit">Unit</th>
            <th class="col-price">Unit Price</th>
            <th class="col-tax">Tax %</th>
            <th class="col-total">Amount</th>
          </tr>
        </thead>
        <tbody>
          {% for item in items %}
          <tr class="{% if loop.index is even %}row-even{% endif %}">
            <td class="col-num">{{ loop.index }}</td>
            <td class="col-desc">
              <span class="item-name">{{ item.name }}</span>
              {% if item.description %}
                <span class="item-desc">{{ item.description }}</span>
              {% endif %}
              {% if item.sku %}
                <span class="item-sku">SKU: {{ item.sku }}</span>
              {% endif %}
            </td>
            <td class="col-qty">{{ item.quantity }}</td>
            <td class="col-unit">{{ item.unit | default('') }}</td>
            <td class="col-price">{{ invoice.currency_symbol }}{{ "%.2f"|format(item.unit_price) }}</td>
            <td class="col-tax">
              {% if item.tax_rate is defined %}{{ "%.1f"|format(item.tax_rate) }}%{% else %}—{% endif %}
            </td>
            <td class="col-total">{{ invoice.currency_symbol }}{{ "%.2f"|format(item.line_total) }}</td>
          </tr>
          {% else %}
          <tr>
            <td colspan="7" class="no-items">No line items.</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <!-- ── TOTALS ─────────────────────────────────────────────── -->
    <section class="inv-totals-section">

      {% if invoice.notes %}
      <div class="inv-notes">
        <p class="inv-notes-label">Notes</p>
        <p class="inv-notes-body">{{ invoice.notes }}</p>
      </div>
      {% endif %}

      <div class="inv-totals">
        <div class="inv-totals-row">
          <span class="totals-label">Subtotal</span>
          <span class="totals-value">{{ invoice.currency_symbol }}{{ "%.2f"|format(totals.subtotal) }}</span>
        </div>

        {% if totals.discount %}
        <div class="inv-totals-row">
          <span class="totals-label">
            Discount
            {% if totals.discount_label %}({{ totals.discount_label }}){% endif %}
          </span>
          <span class="totals-value totals-discount">−{{ invoice.currency_symbol }}{{ "%.2f"|format(totals.discount) }}</span>
        </div>
        {% endif %}

        {% for tax in totals.taxes %}
        <div class="inv-totals-row">
          <span class="totals-label">{{ tax.name }} ({{ "%.1f"|format(tax.rate) }}%)</span>
          <span class="totals-value">{{ invoice.currency_symbol }}{{ "%.2f"|format(tax.amount) }}</span>
        </div>
        {% endfor %}

        {% if totals.shipping %}
        <div class="inv-totals-row">
          <span class="totals-label">Shipping</span>
          <span class="totals-value">{{ invoice.currency_symbol }}{{ "%.2f"|format(totals.shipping) }}</span>
        </div>
        {% endif %}

        {% if totals.adjustment %}
        <div class="inv-totals-row">
          <span class="totals-label">Adjustment</span>
          <span class="totals-value">{{ invoice.currency_symbol }}{{ "%.2f"|format(totals.adjustment) }}</span>
        </div>
        {% endif %}

        <div class="inv-totals-row inv-totals-row--grand">
          <span class="totals-label">Total Due</span>
          <span class="totals-value totals-grand">
            {{ invoice.currency }} {{ invoice.currency_symbol }}{{ "%.2f"|format(totals.grand_total) }}
          </span>
        </div>

        {% if totals.amount_paid %}
        <div class="inv-totals-row">
          <span class="totals-label">Amount Paid</span>
          <span class="totals-value totals-paid">−{{ invoice.currency_symbol }}{{ "%.2f"|format(totals.amount_paid) }}</span>
        </div>
        <div class="inv-totals-row inv-totals-row--balance">
          <span class="totals-label">Balance Due</span>
          <span class="totals-value totals-balance">
            {{ invoice.currency }} {{ invoice.currency_symbol }}{{ "%.2f"|format(totals.balance_due) }}
          </span>
        </div>
        {% endif %}
      </div>

    </section>

    <!-- ── PAYMENT INSTRUCTIONS ───────────────────────────────── -->
    {% if payment %}
    <section class="inv-payment">
      <p class="inv-payment-title">Payment Instructions</p>
      <div class="inv-payment-grid">
        {% if payment.bank_name %}
          <span class="pay-label">Bank</span>
          <span class="pay-value">{{ payment.bank_name }}</span>
        {% endif %}
        {% if payment.account_name %}
          <span class="pay-label">Account Name</span>
          <span class="pay-value">{{ payment.account_name }}</span>
        {% endif %}
        {% if payment.account_number %}
          <span class="pay-label">Account No.</span>
          <span class="pay-value">{{ payment.account_number }}</span>
        {% endif %}
        {% if payment.routing_number %}
          <span class="pay-label">Routing No.</span>
          <span class="pay-value">{{ payment.routing_number }}</span>
        {% endif %}
        {% if payment.swift %}
          <span class="pay-label">SWIFT / BIC</span>
          <span class="pay-value">{{ payment.swift }}</span>
        {% endif %}
        {% if payment.iban %}
          <span class="pay-label">IBAN</span>
          <span class="pay-value">{{ payment.iban }}</span>
        {% endif %}
        {% if payment.paypal %}
          <span class="pay-label">PayPal</span>
          <span class="pay-value">{{ payment.paypal }}</span>
        {% endif %}
        {% if payment.instructions %}
          <span class="pay-label">Note</span>
          <span class="pay-value">{{ payment.instructions }}</span>
        {% endif %}
      </div>
    </section>
    {% endif %}

    <!-- ── TERMS ──────────────────────────────────────────────── -->
    {% if invoice.terms %}
    <section class="inv-terms">
      <p class="inv-terms-title">Terms & Conditions</p>
      <p class="inv-terms-body">{{ invoice.terms }}</p>
    </section>
    {% endif %}

    <!-- ── FOOTER ─────────────────────────────────────────────── -->
    <footer class="inv-footer">
      <span>{{ seller.name }}</span>
      <span class="inv-footer-sep">·</span>
      <span>Invoice #{{ invoice.number }}</span>
      <span class="inv-footer-sep">·</span>
      <span>{{ invoice.issue_date }}</span>
      {% if seller.website %}
        <span class="inv-footer-sep">·</span>
        <span>{{ seller.website }}</span>
      {% endif %}
    </footer>

  </div><!-- /.page -->

</body>
</html>
